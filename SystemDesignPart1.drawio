  <diagram name="Uber" id="lK4yRO1Hg6MHUE9kU--w">
    <mxGraphModel dx="925" dy="491" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="IKhMA-_tn-GQOmhvnyer-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;strokeWidth=6;" value="&lt;h1&gt;UBER HLD&lt;/h1&gt;" vertex="1">
          <mxGeometry height="30" width="360" x="270" y="20" as="geometry" />
        </mxCell>
        <mxCell id="IKhMA-_tn-GQOmhvnyer-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;" value="Users&lt;div&gt;&lt;ol&gt;&lt;li&gt;Real User who will book cab&lt;/li&gt;&lt;li&gt;Driver User&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;Functional Requirement&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;Book/Search for a cab&amp;nbsp; **&lt;/li&gt;&lt;li&gt;Cab Types&lt;/li&gt;&lt;li&gt;See nearby cabs&amp;nbsp; **&lt;/li&gt;&lt;li&gt;Set availability&amp;nbsp;&lt;/li&gt;&lt;li&gt;Track Ride&amp;nbsp; **&lt;/li&gt;&lt;li&gt;Share Cab&lt;/li&gt;&lt;li&gt;Estimating time of trip&lt;/li&gt;&lt;li&gt;Cancel Ride&amp;nbsp; **&lt;/li&gt;&lt;li&gt;Notification&amp;nbsp; *&lt;/li&gt;&lt;li&gt;Rating System&lt;/li&gt;&lt;li&gt;Payment Support **&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;Non Functional Requirements&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;Resilient System&lt;/li&gt;&lt;li&gt;Highly Scalable&lt;/li&gt;&lt;li&gt;In Payment there should be high consistent&lt;/li&gt;&lt;li&gt;In Cab booking or serach there should be high availability&amp;nbsp;&lt;/li&gt;&lt;li&gt;Low latency&amp;nbsp;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="500" width="490" x="60" y="70" as="geometry" />
        </mxCell>
        <mxCell id="IKhMA-_tn-GQOmhvnyer-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="Sequence of Event&lt;div&gt;&lt;ol&gt;&lt;li&gt;User will open app&lt;/li&gt;&lt;li&gt;Able to search / book cab&amp;nbsp;&lt;/li&gt;&lt;li&gt;Able to track driver location&amp;nbsp;&lt;/li&gt;&lt;li&gt;Payment&amp;nbsp;&lt;/li&gt;&lt;li&gt;Done travel . This is one is from real user side .&amp;nbsp;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="410" x="70" y="630" as="geometry" />
        </mxCell>
        <mxCell id="IKhMA-_tn-GQOmhvnyer-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="Capacity Estimation&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Storage Estimation&lt;br&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Daily Active User 40 million per day&amp;nbsp;&lt;/li&gt;&lt;li&gt;All over world it has 10 million driver active daily&amp;nbsp;&lt;/li&gt;&lt;li&gt;80 million rides per day&amp;nbsp;&lt;/li&gt;&lt;li&gt;1 rides - destinationdetail , source detail , price , driverId .&amp;nbsp;&lt;/li&gt;&lt;li&gt;driver per unit location is also going to store like latititude and longiturde .&amp;nbsp;&lt;/li&gt;&lt;li&gt;1 unit of loc info let take 20 bytes every 3 second it is sending&amp;nbsp;&lt;/li&gt;&lt;li&gt;10 minutes is sending - 10 X 60 = 600 second / 3 = 200 times .&amp;nbsp;&lt;/li&gt;&lt;li&gt;200 times X 20 bytes = 4k bytes . 4 KB&amp;nbsp;&lt;/li&gt;&lt;li&gt;50 bytes . 5KB for 1 rides data going to store&amp;nbsp;&lt;/li&gt;&lt;li&gt;80 million rides per day&amp;nbsp;&lt;/li&gt;&lt;li&gt;80 X 10^6 X 5 X 10 ^3&lt;/li&gt;&lt;li&gt;400 GB storage per day .&amp;nbsp;&lt;/li&gt;&lt;li&gt;For 5 years - 400 X 5 X 365&amp;nbsp;&lt;/li&gt;&lt;li&gt;8 X 10^14&lt;/li&gt;&lt;li&gt;800 TB&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;Bandwidht Estimation&amp;nbsp;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;400 GB per day&amp;nbsp;&lt;/li&gt;&lt;li&gt;1 million per day = 11.57 ~ 12 per seconds&lt;/li&gt;&lt;li&gt;400 X 10 ^ 3 X 10^6&amp;nbsp;&amp;nbsp;&lt;/li&gt;&lt;li&gt;400 X 10^3 X 12&lt;/li&gt;&lt;li&gt;4.8 X 10^6 bytes per seconds&lt;/li&gt;&lt;li&gt;4.8 MB/seconds storage ingress&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
