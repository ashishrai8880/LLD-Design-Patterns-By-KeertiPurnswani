        <mxCell id="gjy7k7bxSLRuD5FBMDMr-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Verdana;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Functional Requirement&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ol&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;One to one chat&amp;nbsp; **&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Group Chat&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Status seen&amp;nbsp; **&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Video call **&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Read Reciep&amp;nbsp; **&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Profile&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Notification&amp;nbsp; **&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Voice Notes&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Picture&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Contacts&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Media Upload&amp;nbsp; **&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;Non Functional Requiremet&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Reliable&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Low Latency&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Resilient&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Consistent Order&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;Througput&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Verdana&quot;&gt;High Avaialbility&amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="370" width="570" x="50" y="20" as="geometry" />
        </mxCell>
        <mxCell id="gjy7k7bxSLRuD5FBMDMr-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="Sequence Of Event&lt;div&gt;&lt;ol&gt;&lt;li&gt;User will open Chat APP&lt;/li&gt;&lt;li&gt;Able to see all his messages&amp;nbsp;&lt;/li&gt;&lt;li&gt;Able to see message of one to one chat and group chat&amp;nbsp;&lt;/li&gt;&lt;li&gt;Able to chat and attach media with it&amp;nbsp;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="560" x="60" y="430" as="geometry" />
        </mxCell>
        <mxCell id="gjy7k7bxSLRuD5FBMDMr-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="Capacity Estimation&lt;div&gt;1. Daily Active User is 2 Billion = 2 X 10*^9&lt;/div&gt;&lt;div&gt;Daily Message transfer would be 100 billion&amp;nbsp;&lt;/div&gt;&lt;div&gt;If one chat have 100 bytes and 10% is pics and 5% with video&amp;nbsp;&lt;/div&gt;&lt;div&gt;!pics size is 200KB and 1 video size is 5MB&lt;/div&gt;&lt;div&gt;10 billion pics and 5 billion video&amp;nbsp;&lt;/div&gt;&lt;div&gt;(10 billion X 200 X 10^3 ) + (5 billion X 5 X 10^6) + (100 billion X 100)&lt;/div&gt;&lt;div&gt;(10 ^ 15) + (25 X 10^15) + (10 X 10^12)&lt;/div&gt;&lt;div&gt;10PB + 25 PB + 10TB&lt;/div&gt;&lt;div&gt;35 PB per day message transfer&lt;/div&gt;&lt;div&gt;So for 5 Years = 5 X 365 X 35 PB&amp;nbsp;&lt;/div&gt;&lt;div&gt;70 Exabytes for 5 years .&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Bandwidth Estimation&amp;nbsp;&lt;/div&gt;&lt;div&gt;For 1 day it is 35PB&amp;nbsp;&lt;/div&gt;&lt;div&gt;1 million per day something is 11.57 / seconds&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp;35 X 10 ^ 15&amp;nbsp;&lt;/div&gt;&lt;div&gt;35 X 10^9 X 10^6&lt;/div&gt;&lt;div&gt;35 GB X 11.57&amp;nbsp;&lt;/div&gt;&lt;div&gt;350 GB per seconds storage Ingrees&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="330" width="570" x="60" y="640" as="geometry" />
        </mxCell>
